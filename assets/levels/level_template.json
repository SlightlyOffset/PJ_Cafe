{
  /* 
    P'J Cafe - Level Template Guide
    -------------------------------
    This template defines the JSON structure for creating levels.
    Note: Standard JSON does not support comments; ensure they are removed 
    if your parser is strict. libGDX's Json reader supports them by default.
  */

  "cols": 3, // Total number of columns (integer)
  "rows": 3, // Total number of rows (integer)

  /* 
    "tiles" is a 2D array: [rows][columns]
    Top-level lists represent rows (starting from Y=0 at the bottom).
    Inner objects represent individual tiles in that row (starting from X=0 at the left).
  */
  "tiles": [
    [
      { 
        /* 
          "type": Tile connection pattern. 
          Available: [STRAIGHT, L_TURN, T_JUNCTION, CROSS] 
        */
        "type": "L_TURN", 
        
        /* 
          "rotation": Initial orientation in degrees.
          Valid values: [0, 90, 180, 270] 
        */
        "rotation": 0 
      },
      { "type": "STRAIGHT", "rotation": 90 },
      { "type": "L_TURN", "rotation": 90 }
    ],
    [
      { "type": "STRAIGHT", "rotation": 0 },
      { "type": "CROSS", "rotation": 0 },
      { "type": "STRAIGHT", "rotation": 0 }
    ],
    [
      { "type": "L_TURN", "rotation": 270 },
      { "type": "STRAIGHT", "rotation": 90 },
      { "type": "L_TURN", "rotation": 180 }
    ]
  ]
}
